{
  "name": "@menumaker/shared",
  "version": "1.0.0",
  "description": "Shared types and utilities for MenuMaker",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "api:generate": "openapi-typescript ../openapi/menumaker.v1.yaml -o src/generated/api.ts",
    "api:check": "npm run api:generate && git diff --exit-code -- src/generated/api.ts",
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "tsc"
  },
  "devDependencies": {
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "zod": "^3.22.4"
  }
}
